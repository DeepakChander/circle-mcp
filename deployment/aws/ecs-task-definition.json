{
  "family": "circle-mcp-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "circle-mcp",
      "image": "YOUR_ECR_REPOSITORY_URL:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3001"
        },
        {
          "name": "HOST",
          "value": "0.0.0.0"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "CIRCLE_HEADLESS_BASE_URL",
          "value": "https://app.circle.so"
        }
      ],
      "secrets": [
        {
          "name": "CIRCLE_HEADLESS_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:circle-mcp/headless-token"
        },
        {
          "name": "CIRCLE_ADMIN_V2_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:circle-mcp/admin-token"
        },
        {
          "name": "CIRCLE_COMMUNITY_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:circle-mcp/community-url"
        },
        {
          "name": "GCP_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:circle-mcp/gcp-client-id"
        },
        {
          "name": "GCP_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:circle-mcp/gcp-client-secret"
        },
        {
          "name": "GCP_REDIRECT_URI",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:circle-mcp/gcp-redirect-uri"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/circle-mcp-server",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3001/health', (r) => { process.exit(r.statusCode === 200 ? 0 : 1); })\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
