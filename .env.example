# Circle MCP Server - Environment Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# Circle Community Configuration
# ==========================================

# Circle Headless Token (Required)
# Get from: Circle Admin → Settings → API
CIRCLE_HEADLESS_TOKEN=your_circle_headless_token_here

# Circle Admin V2 Token (Optional)
CIRCLE_ADMIN_V2_TOKEN=your_admin_v2_token_here

# Circle Community URL (Required)
CIRCLE_COMMUNITY_URL=https://your-community.circle.so

# Circle API Base URL (Required)
CIRCLE_HEADLESS_BASE_URL=https://app.circle.so

# ==========================================
# Google Cloud Platform OAuth Configuration
# ==========================================

# GCP Client ID (Required)
# Get from: https://console.cloud.google.com/apis/credentials
GCP_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# GCP Client Secret (Required)
GCP_CLIENT_SECRET=GOCSPX-your-client-secret-here

# GCP Redirect URI (Required)
# For production: http://circle-mcp.duckdns.org:3000/auth/google/callback
# For local: http://localhost:3000/auth/google/callback
GCP_REDIRECT_URI=http://circle-mcp.duckdns.org:3000/auth/google/callback

# OAuth Port (Optional, default: 3000)
OAUTH_PORT=3000

# ==========================================
# HTTP/WebSocket Server Configuration
# ==========================================

# Server Port (Optional, default: 3000)
PORT=3000

# Server Host (Optional, default: 0.0.0.0)
HOST=0.0.0.0

# Public Domain (Optional, default: circle-mcp.duckdns.org)
PUBLIC_DOMAIN=circle-mcp.duckdns.org

# Allowed CORS Origins (Optional, default: *)
ALLOWED_ORIGINS=*

# ==========================================
# Server Configuration
# ==========================================

# Node Environment (Optional, default: development)
NODE_ENV=production

# Log Level (Optional, default: info)
LOG_LEVEL=info

# Read-Only Mode (Optional, default: false)
READ_ONLY_MODE=false

# Enable Rate Limiting (Optional, default: true)
ENABLE_RATE_LIMITING=true

# Max Requests Per Minute (Optional, default: 60)
MAX_REQUESTS_PER_MINUTE=60

# Cache TTL Seconds (Optional, default: 300)
CACHE_TTL_SECONDS=300