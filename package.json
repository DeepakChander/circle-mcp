{
  "name": "circle-mcp-server",
  "version": "2.0.0",
  "description": "Production-grade MCP server for Circle community platform with OAuth 2.1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "circle-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http-server.ts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "circle",
    "circle-mcp",
    "circle-so",
    "circle-lms",
    "circle-community",
    "model-context-protocol",
    "mcp-server",
    "admin-api",
    "llm",
    "ai",
    "oauth",
    "cursor",
    "claude",
    "vscode"
  ],
  "author": "Circle MCP Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.4.0",
    "googleapis": "^162.0.0",
    "open": "^10.2.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
